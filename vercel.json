{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|svg|webmanifest|html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!app\\.js|styles\\.css|sw\\.js|icon\\.svg|manifest\\.webmanifest|offline\\.html).*)",
      "destination": "/index.html"
    }
  ]
}
